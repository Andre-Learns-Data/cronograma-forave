# ============================================================
# .env — Credenciais e configurações sensíveis
# ============================================================
# COPIA este ficheiro para .env e preenche com os teus dados.
# O ficheiro .env NUNCA vai para o GitHub (está no .gitignore).
# ============================================================

# --- Email por SMTP (envio local, no PC do coordenador) ---
# Para Gmail: usa uma App Password, não a password normal.
# Instruções: myaccount.google.com → Segurança → Passwords de apps
# (SERVIDOR/PORTA são opcionais — por defeito assume-se o Gmail.)
EMAIL_REMETENTE=gestor.cronograma@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop
EMAIL_SERVIDOR=smtp.gmail.com
EMAIL_PORTA=587

# --- Email por HTTP (Brevo) — necessário no ALOJAMENTO ---
# O Render gratuito bloqueia o SMTP; no site usa-se a API HTTP do Brevo.
# Cria conta grátis em brevo.com, verifica o remetente e gera a API key.
# Se BREVO_API_KEY estiver definido, o site usa o Brevo; senão, o Gmail/SMTP.
BREVO_API_KEY=

# --- Área de administração (coordenador) ---
# Emails que entram como COORDENADOR (acesso a /admin), separados por vírgula.
COORDENADOR_EMAILS=

# --- Google Sheets ---
# ID (ou nome) da spreadsheet
GOOGLE_SHEETS_NOME=Cronograma FORAVE
# Caminho para o ficheiro de credenciais do Service Account
GOOGLE_SHEETS_CREDENCIAIS=credentials.json
